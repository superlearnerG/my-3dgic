ninja_required_version = 1.3
cxx = /usr/bin/g++
nvcc = /home/pj/anaconda3/envs/3dgic/bin/nvcc

cflags = -Wno-unused-result -Wsign-compare -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /home/pj/anaconda3/envs/3dgic/include -fPIC -O2 -isystem /home/pj/anaconda3/envs/3dgic/include -DNDEBUG -D_FORTIFY_SOURCE=2 -O2 -isystem /home/pj/anaconda3/include -I/home/pj/anaconda3/targets/x86_64-linux/include -L/home/pj/anaconda3/targets/x86_64-linux/lib -L/home/pj/anaconda3/targets/x86_64-linux/lib/stubs -I/home/pj/anaconda3/envs/3dgic/targets/x86_64-linux/include -L/home/pj/anaconda3/envs/3dgic/targets/x86_64-linux/lib -L/home/pj/anaconda3/envs/3dgic/targets/x86_64-linux/lib/stubs -fPIC -I/home/pj/anaconda3/envs/3dgic/lib/python3.10/site-packages/torch/include -I/home/pj/anaconda3/envs/3dgic/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/pj/anaconda3/envs/3dgic/include -I/home/pj/anaconda3/envs/3dgic/include/python3.10 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1016"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=1 -std=c++17
cuda_cflags = -I/home/pj/anaconda3/envs/3dgic/lib/python3.10/site-packages/torch/include -I/home/pj/anaconda3/envs/3dgic/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/pj/anaconda3/envs/3dgic/include -I/home/pj/anaconda3/envs/3dgic/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1016"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=1 -gencode=arch=compute_89,code=compute_89 -gencode=arch=compute_89,code=sm_89 -ccbin /usr/bin/gcc -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







