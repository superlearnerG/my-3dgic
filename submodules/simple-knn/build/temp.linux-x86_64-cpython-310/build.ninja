build /home/pj/Desktop/data/tron_future_3dgic/submodules/simple-knn/build/temp.linux-x86_64-cpython-310/simple_knn.o: cuda_compile /home/pj/Desktop/data/tron_future_3dgic/submodules/simple-knn/simple_knn.cu
build /home/pj/Desktop/data/tron_future_3dgic/submodules/simple-knn/build/temp.linux-x86_64-cpython-310/spatial.o: cuda_compile /home/pj/Desktop/data/tron_future_3dgic/submodules/simple-knn/spatial.cu








